    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:clear-users": "tsx scripts/clear-usuarios.ts",
    "db:clear-schedules": "tsx scripts/clear-schedules.ts",
    "db:seed-usuarios": "tsx scripts/seed-usuarios-sistema.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.22.0",
    "@rota-eletronica/shared-types": "file:../../packages/shared-types",
    "archiver": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "jsonwebtoken": "^9.0.2",
    "unzipper": "^0.12.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.0",
    "@types/unzipper": "^0.10.11",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "~5.3.3",
    "vitest": "^3.2.4"
  }

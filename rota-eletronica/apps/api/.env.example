# Database: usar o database UrbanData no PostgreSQL local.
# Usar usuário postgres (admin) para criar tabelas e rodar migrações/seed (nunca commitar .env).
DATABASE_URL="postgresql://postgres:SUA_SENHA@localhost:5432/UrbanData"

# JWT: chave secreta para assinar tokens (gerar uma string aleatória longa em produção).
JWT_SECRET="sua-chave-secreta-jwt-minimo-32-chars"

# Porta da API (opcional; padrão 3001).
PORT=3001

# Opcional: senha com ≥16 caracteres — ativa cifrado AES-256-GCM da coluna foto_perfil (usuários).
# Sem esta variável, a foto continua gravada no PostgreSQL, porém em texto (data URL).
# AT_REST_ENCRYPTION_KEY="defina-uma-frase-secreta-longa-aqui"

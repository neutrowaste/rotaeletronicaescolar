# URL da API backend (PostgreSQL UrbanData). Padrão: http://localhost:3001
VITE_API_URL=http://localhost:3001

# Chave da API do Google Maps (Maps JavaScript API + Places)
# Crie um arquivo .env e defina sua chave, ou use a chave de desenvolvimento já configurada no código.
VITE_GOOGLE_MAPS_API_KEY=sua_chave_aqui
